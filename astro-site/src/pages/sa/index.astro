---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MarketLanding from "../../components/MarketLanding.astro";
import { getMarketByCode } from "../../config/markets";
import { buildMarketMeta } from "../../config/seo";
import { mergeMarketWithCms } from "../../lib/cms";

const rawMarket = getMarketByCode("sa");
if (!rawMarket) throw new Error("Missing market config: sa");
const market = mergeMarketWithCms(rawMarket);
const meta = buildMarketMeta(market);
---
<BaseLayout lang="ar" dir="rtl" meta={meta}>
  <MarketLanding market={market} />
</BaseLayout>
