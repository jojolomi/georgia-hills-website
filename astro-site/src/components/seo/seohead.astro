---
import type { SeoContract } from "./contract";

interface Props {
  seo: SeoContract;
}

const { seo } = Astro.props;
const searchConsoleVerification = import.meta.env.PUBLIC_SEARCH_CONSOLE_VERIFICATION || "";
const googleAdsId = import.meta.env.PUBLIC_GOOGLE_ADS_ID || "";
---
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<meta name="robots" content={seo.robots} />
<title>{seo.title}</title>
<meta name="description" content={seo.description} />
{searchConsoleVerification && <meta name="google-site-verification" content={searchConsoleVerification} />}
<link rel="canonical" href={seo.canonical} />

{seo.hreflangs.map((item) => (
  <link rel="alternate" hreflang={item.hreflang} href={item.href} />
))}

<meta property="og:type" content="website" />
<meta property="og:url" content={seo.canonical} />
<meta property="og:title" content={seo.title} />
<meta property="og:description" content={seo.description} />
<meta property="og:image" content={seo.ogImage} />
<meta property="og:locale" content={seo.lang === "ar" ? "ar_SA" : "en_US"} />
<meta name="twitter:card" content={seo.twitterCard} />
<meta name="theme-color" content="#0F172A" />

<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="manifest" href="/manifest.json" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="stylesheet" href="/style.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" media="print" onload="this.media='all'" />
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />

<script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", "@graph": seo.schemaGraph })}></script>

<script is:inline define:vars={{ googleAdsId }}>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  const gtagId = 'G-6GT03GSW49';
  gtag('consent', 'default', {
    ad_storage: 'denied',
    ad_user_data: 'denied',
    ad_personalization: 'denied',
    analytics_storage: 'denied'
  });
  function loadGTM() {
    if (window.gtmLoaded) return;
    window.gtmLoaded = true;
    const script = document.createElement('script');
    script.src = 'https://www.googletagmanager.com/gtag/js?id=' + gtagId;
    script.async = true;
    document.head.appendChild(script);
    gtag('js', new Date());
    gtag('config', gtagId);
    if (googleAdsId) {
      gtag('config', googleAdsId);
    }
  }
  ['mousedown', 'mousemove', 'keydown', 'scroll', 'touchstart'].forEach((evt) => {
    window.addEventListener(evt, loadGTM, { once: true, passive: true });
  });
  setTimeout(loadGTM, 4000);
</script>
