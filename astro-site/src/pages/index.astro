---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroVariant from "../components/seo/HeroVariant.astro";
import TrustStrip from "../components/trust/TrustStrip.astro";
import { homeEnMeta as meta } from "../config/seo";
---
<BaseLayout lang="en" dir="ltr" meta={meta}>
  <section class="hero" id="home" style="height:90vh; min-height:640px;">
    <div class="hero-bg-container">
      <video class="hero-video" autoplay muted loop playsinline preload="none" poster="/image-1024.webp" aria-hidden="true">
        <source src="https://cdn.coverr.co/videos/coverr-railway-bridge-1579/1080p.mp4" type="video/mp4" />
      </video>
      <picture>
        <source type="image/avif" srcset="/image-320.avif 320w, /image-640.avif 640w, /image-1024.avif 1024w, /image-1600.avif 1600w" sizes="100vw" />
        <source type="image/webp" srcset="/image-320.webp 320w, /image-640.webp 640w, /image-1024.webp 1024w, /image-1600.webp 1600w" sizes="100vw" />
        <img src="/image-1024.webp" class="hero-img" alt="Private tours in Georgia" loading="eager" decoding="async" fetchpriority="high" />
      </picture>
      <div class="hero-overlay"></div>
    </div>
    <HeroVariant lang="en" fallbackIntent="family" />
  </section>
  <TrustStrip lang="en" />
</BaseLayout>
