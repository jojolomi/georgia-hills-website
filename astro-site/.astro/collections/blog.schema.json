{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "lang": {
      "type": "string",
      "enum": [
        "en",
        "ar"
      ]
    },
    "intent": {
      "type": "string",
      "enum": [
        "planning",
        "cost",
        "itinerary",
        "halal",
        "safety"
      ]
    },
    "market": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "sa",
          "ae",
          "qa",
          "kw",
          "eg"
        ]
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "lang",
    "intent",
    "market"
  ]
}